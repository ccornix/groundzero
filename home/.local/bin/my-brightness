#!/usr/bin/env bash
# Dependencies: brightnessctl ddcutil fuzzel

set  -euo pipefail

levels=(0 1 3 7 13 22 33 46 61 79 100)  # round(100 * x^2.2), 0 <= x <= 1

next() {
  for i in "${!levels[@]}"; do
    level=${levels[$i]}
    [[ $level -gt $1 ]] && break
  done
  echo "$level"
}

prev() {
  for ((i=${#levels[@]}-1; i>=0; i--)); do
    level=${levels[$i]}
    [[ $level -lt $1 ]] && break
  done
  echo "$level"
}

choose() {
  ans="$(fuzzel -d \
    --prompt-only="$1 display brightness level [0-$((${#levels[@]}-1))] > " \
    --width=45
  )"
  [[ -z "$ans" ]] || echo "${levels[$ans]}"
}

if [[ "${2:-}" == "--ddc" ]]; then
  opts=('--sleep-multiplier=0.5')
  current() { ddcutil getvcp 10 --terse "${opts[@]}" | cut -d' ' -f 4; }
  setbr() { [[ -z "$1" ]] || ddcutil setvcp 10 "$1" "${opts[@]}"; }
  prefix="External"
else
  current() { brightnessctl -m i | cut -d',' -f 4 | tr -d '%'; }
  setbr() { [[ -z "$1" ]] || brightnessctl -q set "$1%"; }
  prefix="Internal"
fi

case ${1:-} in
  raise) setbr "$(next "$(current)")";;
  lower) setbr "$(prev "$(current)")";;
  entry) setbr "$(choose "$prefix")";;
  *) echo "usage: $(basename "$0") { raise | lower | entry } [--ddc]" >&2 &&
     exit 1;;
esac


#!/usr/bin/env bash
# Dependencies: brightnessctl ddcutil fuzzel

set  -euo pipefail

levels=(0 1 3 7 13 22 33 46 61 79 100)  # round(100 * x^2.2), 0 <= x <= 1

current() { brightnessctl -m i | cut -d',' -f 4 | tr -d '%'; }

list() { for i in "${!levels[@]}"; do echo "${i}: ${levels[$i]}"; done; }

next() {
  for i in "${!levels[@]}"; do
    level=${levels[$i]}
    [[ $level -gt $1 ]] && break
  done
  echo "$level"
}

prev() {
  for ((i=${#levels[@]}-1; i>=0; i--)); do
    level=${levels[$i]}
    [[ $level -lt $1 ]] && break
  done
  echo "$level"
}

choose() {
  fuzzel -d --prompt-only "Brightness level [0-$((${#levels[@]}-1))] > "
}

if [[ "${2:-}" == "--ddc" ]]; then
  setbr() { ddcutil setvcp 10 "$1"; }
else
  setbr() { brightnessctl -q set "$1%"; }
fi

case ${1:-} in
  raise) setbr "$(next "$(current)")";;
  lower) setbr "$(prev "$(current)")";;
  entry) setbr "${levels[$(choose)]}";;
  *) echo "usage: $(basename "$0") { raise | lower | entry } [--ddc]" >&2 &&
     exit 1;;
esac

